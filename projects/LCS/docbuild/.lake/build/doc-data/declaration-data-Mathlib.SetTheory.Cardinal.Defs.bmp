/Defs.html#Cardinal.«term#_»","kind":"def","line":88,"name":"Cardinal.«term#_»","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/SetTheory/Cardinal/Defs.lean#L88-L89"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/SetTheory/Cardinal/Defs.html#Cardinal.mk\"><span class=\"name\">Cardinal</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./Mathlib/SetTheory/Cardinal/Defs.html#Cardinal\">Cardinal.{u}</a></span></div></div>","info":{"doc":"The cardinal number of a type ","docLink":"./Mathlib/SetTheory/Cardinal/Defs.html#Cardinal.mk","kind":"def","line":84,"name":"Cardinal.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/SetTheory/Cardinal/Defs.lean#L84-L86"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/SetTheory/Cardinal/Defs.html#Cardinal\"><span class=\"name\">Cardinal</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (u + 1)</div></div>","info":{"doc":"`Cardinal.{u}` is the type of cardinal numbers in `Type u`,\ndefined as the quotient of `Type u` by existence of an equivalence\n(a bijection with explicit inverse). ","docLink":"./Mathlib/SetTheory/Cardinal/Defs.html#Cardinal","kind":"def","line":75,"name":"Cardinal","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/SetTheory/Cardinal/Defs.lean#L75-L80"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/SetTheor