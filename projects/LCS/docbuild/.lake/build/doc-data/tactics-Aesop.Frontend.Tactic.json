[{"userName": "aesop",
  "tags": [],
  "internalName": "Aesop.Frontend.Parser.aesopTactic",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "aesop"}, {"text": " "}, {"text": "<clause>*"}]]},
        {"text": " tries to solve the current goal by applying a set of rules"},
        {"raw": "\n"},
        {"text": "registered with the "},
        {"element": ["code", true, [], [{"text": "@[aesop]"}]]},
        {"text": " attribute. See "},
        {"element":
         ["a",
          true,
          [["href", "https://github.com/JLimperg/aesop#readme"]],
          [{"text": "its"}, {"raw": "\n"}, {"text": "README"}]]},
        {"text": " for a tutorial and a"},
        {"raw": "\n"},
        {"text": "reference."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "The variant "},
        {"element": ["code", true, [], [{"text": "aesop?"}]]},
        {"text": " prints the proof it found as a "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "Try"}, {"text": " "}, {"text": "this"}]]},
        {"text": " suggestion."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "Clauses can be used to customise the behaviour of an Aesop call. Available"},
        {"raw": "\n"},
        {"text": "clauses are:"}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "(add"},
              {"text": " "},
              {"text": "<phase>"},
              {"text": " "},
              {"text": "<priority>"},
              {"text": " "},
              {"text": "<builder>"},
              {"text": " "},
              {"text": "<rule>)"}]]},
           {"text": " adds a rule. "},
           {"element": ["code", true, [], [{"text": "<phase>"}]]},
           {"text": " is"},
           {"raw": "\n"},
           {"element": ["code", true, [], [{"text": "unsafe"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "safe"}]]},
           {"text": " or "},
           {"element": ["code", true, [], [{"text": "norm"}]]},
           {"text": ". "},
           {"element": ["code", true, [], [{"text": "<priority>"}]]},
           {"text": " is a percentage for unsafe rules and"},
           {"raw": "\n"},
           {"text": "an integer for safe and norm rules. "},
           {"element": ["code", true, [], [{"text": "<rule>"}]]},
           {"text": " is the name of a declaration or"},
           {"raw": "\n"},
           {"text": "local hypothesis. "},
           {"element": ["code", true, [], [{"text": "<builder>"}]]},
           {"text": " is the rule builder used to turn "},
           {"element": ["code", true, [], [{"text": "<rule>"}]]},
           {"text": " into"},
           {"raw": "\n"},
           {"text": "an Aesop rule. Example: "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(add"},
              {"text": " "},
              {"text": "unsafe"},
              {"text": " "},
              {"text": "50%"},
              {"text": " "},
              {"text": "apply"},
              {"text": " "},
              {"text": "Or.inl)"}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "(erase"}, {"text": " "}, {"text": "<rule>)"}]]},
           {"text": " disables a globally registered Aesop rule. Example: "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(erase"},
              {"text": ""},
              {"text": " "},
              {"text": ""},
              {"text": "Aesop.BuiltinRules.assumption)"}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "(rule_sets"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "[<ruleset>,*])"}]]},
           {"text": " enables or disables named sets of rules for"},
           {"raw": "\n"},
           {"text": "this Aesop call. Example: "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(rule_sets"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "[-builtin,"},
              {"text": " "},
              {"text": "MyRuleSet])"}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "(config"},
              {"text": " "},
              {"text": "{"},
              {"text": " "},
              {"text": "<opt>"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "<value>"},
              {"text": " "},
              {"text": "})"}]]},
           {"text": " adjusts Aesop's search options. See"},
           {"raw": "\n"},
           {"element":
            ["code",
             true,
             [],
             [{"element":
               ["a",
                true,
                [["href", "./Aesop/Options/Public.html#Aesop.Options"]],
                [{"text": "Aesop.Options"}]]}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "(simp_config"},
              {"text": " "},
              {"text": "{"},
              {"text": " "},
              {"text": "<opt>"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "<value>"},
              {"text": " "},
              {"text": "})"}]]},
           {"text": " adjusts options for Aesop's built-in"},
           {"raw": "\n"},
           {"element": ["code", true, [], [{"text": "simp"}]]},
           {"text": " rule. The given options are directly passed to "},
           {"element": ["code", true, [], [{"text": "simp"}]]},
           {"text": ". For example,"},
           {"raw": "\n"},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(simp_config"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "{"},
              {"text": " "},
              {"text": "zeta"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "false"},
              {"text": " "},
              {"text": "})"}]]},
           {"text": " makes Aesop use"},
           {"raw": "\n"},
           {"element":
            ["code",
             true,
             [],
             [{"text": "simp"},
              {"text": " "},
              {"text": "(config"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "{"},
              {"text": " "},
              {"text": "zeta"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "false"},
              {"text": " "},
              {"text": "})"}]]},
           {"text": "."}]]}]]}]]},
  "definingModule": "Aesop.Frontend.Tactic"},
