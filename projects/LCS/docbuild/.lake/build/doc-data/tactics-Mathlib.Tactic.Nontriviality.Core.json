           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Mathlib/Logic/Nontrivial/Defs.html#Nontrivial"]],
             [{"text": "Nontrivial"}]]},
           {"text": " "},
           {"text": "α"}]]},
        {"text": ", and attempt to discharge"},
        {"raw": "\n"},
        {"text": "the "},
        {"element":
