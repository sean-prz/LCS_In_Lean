          [{"element":
            ["a",
             true,
             [["href", "./Mathlib/Logic/Nontrivial/Defs.html#Nontrivial"]],
             [{"text": "Nontrivial"}]]}]]},
        {"text": " instance directly."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "Otherwise, it will perform a case split on "},
        {"element":
         ["code",
