          [],
          [{"text": "nontriviality"}, {"text": " "}, {"text": "α"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "The "},
        {"element": ["code", true, [], [{"text": "nontriviality"}]]},
        {"text":
         " tactic will first look for strict inequalities amongst the hypotheses,"},
        {"raw": "\n"},
        {"text": "and use these to derive the "},
