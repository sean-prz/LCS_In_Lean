        {"text":
         "by proof irrelevance, this adds no observable complexity."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "With "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "rewrite!"},
           {"text": " "},
           {"text": "+letAbs"},
           {"text": " "},
           {"text": "(castMode"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": ".all)"}]]},
        {"text": ", casts are inserted whenever necessary."},
        {"raw": "\n"},
        {"text":
         "This means that the 'motive is not type correct' error never occurs,"},
