     {"element":
      ["p",
       true,
       [],
       [{"text": "The sort of casts that are inserted is controlled by the "},
        {"element": ["code", true, [], [{"text": "castMode"}]]},
        {"text": " configuration option."},
        {"raw": "\n"},
        {"text": "By default, only proof terms are casted;"},
