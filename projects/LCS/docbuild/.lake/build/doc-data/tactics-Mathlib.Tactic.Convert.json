        {"text": ") in "},
        {"element": ["code", true, [], [{"text": "t"}]]},
        {"text": " that are not solved by unification are converted"},
        {"raw": "\n"},
        {"text":
         "into new goals, using the hole's name, if any, as the goal case name."},
        {"raw": "\n"},
        {"text": "Like "},
        {"element": ["code", true, [], [{"text": "congr!"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "convert_to"}]]},
        {"text":
         " introduces variables while applying congruence rules. These can be"},
        {"raw": "\n"},
        {"text": "pattern-matched, like "},
        {"element": ["code", true, [], [{"text": "rintro"}]]},
        {"text": " would, using the "},
        {"element": ["code", true, [], [{"text": "with"}]]},
        {"text": " keyword."}]]},
