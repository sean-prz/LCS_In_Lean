          [],
          [{"text": "t'"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "t"}]]},
        {"text":
         " using congruence, then tries proving these goals by associativity and commutativity. The"},
        {"raw": "\n"},
        {"text": "goals are created like "},
        {"element": ["code", true, [], [{"text": "congr!"}]]},
        {"text": " would."},
        {"raw": "\n"},
        {"text": "In other words, "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "ac_change"}, {"text": " "}, {"text": "t"}]]},
