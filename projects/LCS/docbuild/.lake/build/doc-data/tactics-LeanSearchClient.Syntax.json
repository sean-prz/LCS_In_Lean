  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "Search "},
        {"element":
         ["a",
          true,
          [["href", "https://premise-search.com"]],
          [{"text": "LeanStateSearch"}]]},
        {"text": " from within Lean."},
        {"raw": "\n"},
        {"text":
         "Your current main goal is sent as query. The revision to search can be set"},
        {"raw": "\n"},
        {"text": "using the "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./LeanSearchClient/Basic.html#statesearch.revision"]],
             [{"text": "statesearch.revision"}]]}]]},
        {"text": " option. The number of results can be set"},
        {"raw": "\n"},
        {"text": "using the "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./LeanSearchClient/Basic.html#statesearch.queries"]],
             [{"text": "statesearch.queries"}]]}]]},
        {"text": " option."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "Hint: If you want to modify the query, you need to use the web interface."}]]},
     {"element":
      ["pre",
       true,
       [],
       [{"element":
         ["code",
          true,
          [["class", "language-lean"]],
          [{"text": "set_option"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./LeanSearchClient/Basic.html#statesearch.queries"]],
             [{"text": "statesearch.queries"}]]},
           {"text": " "},
           {"text": "1"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": "set_option"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./LeanSearchClient/Basic.html#statesearch.revision"]],
             [{"text": "statesearch.revision"}]]},
           {"text": " "},
           {"text": "\"v4.16.0\""},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": "example"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "0"},
           {"text": " "},
           {"text": "≤"},
           {"text": " "},
           {"text": "1"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "by"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "#statesearch"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "sorry"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "You can modify the LeanStateSearch URL by setting the "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "LEANSEARCHCLIENT_LEANSTATESEARCH_API_URL"}]]},
        {"text": " environment variable."}]]}]]},
