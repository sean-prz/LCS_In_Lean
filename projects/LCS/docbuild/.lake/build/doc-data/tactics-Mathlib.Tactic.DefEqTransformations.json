[{"userName": "beta_reduce",
  "tags": [],
  "internalName": "Mathlib.Tactic.betaReduceStx",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "beta_reduce"},
           {"text": " "},
           {"text": "at"},
           {"text": " "},
           {"text": "loc"}]]},
        {"text": " completely beta reduces the given location."},
        {"raw": "\n"},
        {"text": "This also exists as a "},
        {"element": ["code", true, [], [{"text": "conv"}]]},
        {"text": "-mode tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "This means that whenever there is an applied lambda expression such as"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "(fun"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "=>"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "x)"},
           {"text": " "},
           {"text": "y"}]]},
        {"text":
         " then the argument is substituted into the lambda expression"},
        {"raw": "\n"},
        {"text": "yielding an expression such as "},
        {"element":
         ["code", true, [], [{"text": "f"}, {"text": " "}, {"text": "y"}]]},
        {"text": "."}]]}]]},
  "definingModule": "Mathlib.Tactic.DefEqTransformations"},
 {"userName": "eta_struct",
  "tags": [],
  "internalName": "Mathlib.Tactic.etaStructStx",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "eta_struct"},
           {"text": " "},
           {"text": "at"},
           {"text": " "},
           {"text": "loc"}]]},
        {"text": " transforms structure constructor applications such as "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "S.mk"},
           {"text": " "},
           {"text": "x.1"},
           {"text": " "},
           {"text": "..."},
           {"text": " "},
           {"text": "x.n"}]]},
        {"raw": "\n"},
        {"text": "(pretty printed as, for example, "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "{a"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "x.a,"},
           {"text": " "},
           {"text": "b"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "x.b,"},
           {"text": " "},
           {"text": "...}"}]]},
        {"text": ") into "},
        {"element": ["code", true, [], [{"text": "x"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text": "This also exists as a "},
        {"element": ["code", true, [], [{"text": "conv"}]]},
        {"text": "-mode tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "The transformation is known as eta reduction for structures, and it yields definitionally"},
        {"raw": "\n"},
        {"text": "equal expressions."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "For example, given "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "x"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "α"},
           {"text": " "},
           {"text": "×"},
           {"text": " "},
           {"text": "β"}]]},
        {"text": ", then "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "(x.1,"}, {"text": " "}, {"text": "x.2)"}]]},
        {"text": " becomes "},
        {"element": ["code", true, [], [{"text": "x"}]]},
        {"text": " after this transformation."}]]}]]},
  "definingModule": "Mathlib.Tactic.DefEqTransformations"},
 {"userName": "eta_expand",
  "tags": [],
  "internalName": "Mathlib.Tactic.etaExpandStx",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "eta_expand"},
           {"text": " "},
           {"text": "at"},
           {"text": " "},
           {"text": "loc"}]]},
        {"text": " eta expands all sub-expressions at the given location."},
        {"raw": "\n"},
        {"text":
         "It also beta reduces any applications of eta expanded terms, so it puts it"},
        {"raw": "\n"},
        {"text": "into an eta-expanded \"normal form.\""},
        {"raw": "\n"},
        {"text": "This also exists as a "},
        {"element": ["code", true, [], [{"text": "conv"}]]},
        {"text": "-mode tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "For example, if "},
        {"element": ["code", true, [], [{"text": "f"}]]},
        {"text": " takes two arguments, then "},
        {"element": ["code", true, [], [{"text": "f"}]]},
        {"text": " becomes "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "fun"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "=>"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "y"}]]},
        {"raw": "\n"},
        {"text": "and "},
        {"element":
         ["code", true, [], [{"text": "f"}, {"text": " "}, {"text": "x"}]]},
        {"text": " becomes "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "fun"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "=>"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "y"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "This can be useful to turn, for example, a raw "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#HAdd.hAdd"]],
             [{"text": "HAdd.hAdd"}]]}]]},
        {"text": " into "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "fun"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "=>"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "y"}]]},
        {"text": "."}]]}]]},
  "definingModule": "Mathlib.Tactic.DefEqTransformations"},
