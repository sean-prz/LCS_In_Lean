        {"element":
         ["code",
          true,
          [],
          [{"text": "g"},
           {"text": " "},
           {"text": "(if"},
           {"text": " "},
           {"text": "p"},
           {"text": " "},
           {"text": "then"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "else"},
           {"text": " "},
           {"text": "y)"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "split_ifs"}]]},
        {"text": " will produce"},
        {"raw": "\n"},
        {"text": "two goals: "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "p"},
           {"text": " "},
           {"text": "⊢"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "x"}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "¬p"},
           {"text": " "},
           {"text": "⊢"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "y"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text": "If there are multiple ite-expressions, then "},
        {"element": ["code", true, [], [{"text": "split_ifs"}]]},
        {"text": " will split them all,"},
        {"raw": "\n"},
        {"text":
         "starting with a top-most one whose condition does not contain another"},
        {"raw": "\n"},
        {"text": "ite-expression."},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "split_ifs"},
           {"text": " "},
           {"text": "at"},
           {"text": " "},
           {"text": "*"}]]},
        {"text":
         " splits all ite-expressions in all hypotheses as well as the goal."},
        {"raw": "\n"},
        {"element":
