brev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.post\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Meta</span>.<span class=\"name\">NormNum</span>.<span class=\"name\">NormNumExt</span>.<span class=\"name\">post</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt\">NormNumExt</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The extension should be run in the `post` phase when used as simp plugin. ","docLink":"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.post","kind":"def","line":57,"name":"Mathlib.Meta.NormNum.NormNumExt.post","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/NormNum/Core.lean#L57-L57"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.pre\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Meta</span>.<span class=\"name\">NormNum</span>.<span class=\"name\">NormNumExt</span>.<span class=\"name\">pre</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt\">NormNumExt</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The extension should be run in the `pre` phase when used as simp plugin. ","docLink":"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.pre","kind":"def","line":55,"name":"Mathlib.Meta.NormNum.NormNumExt.pre","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/NormNum/Core.lean#L55-L55"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.mk\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Meta</span>.<span class=\"name\">NormNum</span>.<span class=\"name\">NormNumExt</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pre </span><span class=\"fn\">post</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">eval</span> : <span class=\"fn\">{<span class=\"fn\">u</span> : <a href=\"./Lean/Level.html#Lean.Level\">Lean.Level</a>} → <span class=\"fn\">{<span class=\"fn\">α</span> : <span class=\"fn\">Q(<a href=\"./foundational_types.html\">Type</a> u)</span>} → <span class=\"fn\">(<span class=\"fn\">e</span> : <span class=\"fn\">Q(<span class=\"fn\">«$α»</span>)</span>) → <span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> <span class=\"fn\">(<a href=\"./Mathlib/Tactic/NormNum/Result.html#Mathlib.Meta.NormNum.Result\">Result</a> <span class=\"fn\">e</span>)</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">name</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a> := by exact decl_name%)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt\">NormNumExt</a></div></div>","info":{"doc":"","docLink":"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt.mk","kind":"ctor","line":53,"name":"Mathlib.Meta.NormNum.NormNumExt.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/NormNum/Core.lean#L53-L53"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Meta</span>.<span class=\"name\">NormNum</span>.<span class=\"name\">NormNumExt</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"An extension for `norm_num`.\n","docLink":"./Mathlib/Tactic/NormNum/Core.html#Mathlib.Meta.NormNum.NormNumExt","kind":"structure","line":50,"name":"Mathlib.Meta.NormNum.NormNumExt","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/NormNum/Core.lean#L50-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/NormNum/Core.html#norm_num\"><span class=\"name\">norm_num</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`@[norm_num e]`, where `e` is an expression (optionally with `_`s) adds the tagged definition,\nof type `NormNumExt`, to the set of normalization procedures used by the `norm_num` tactic, such\nthat it will fire on expressions matching the form `e`. Use holes in `e` to indicate arbitrary\nsubexpressions, for example `@[norm_num _ + _]` will match any addition.\n\n* `@[norm_num e1, e2, ...]` will match either `e1` or `e2` or ...\n\nExample:\n```lean\n@[norm_num -_] def evalNeg : NormNumExt where eval {u α} e := do\n  let .app (f : Q($α → $α)) (a : Q($α)) ← whnfR e | failure\n  let ra ← derive a\n  let rα ← inferRing α\n  ra.neg\n```\n","docLink":"./Mathlib/Tactic/NormNum/Core.html#norm_num","kind":"def","line":27,"name":"norm_num","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/NormNum/Core.lean#L27-L43"}}],"imports":["Init","Mathlib.Lean.Expr.Rat","Mathlib.Tactic.Hint","Mathlib.Tactic.NormNum.Result","Mathlib.Util.Qq"],"instances":[{"className":"Inhabited","name":"Mathlib.Meta.NormNum.instInhabitedNormNums","typeNames":["Mathlib.Meta.NormNum.NormNums"]}],"name":"Mathlib.Tactic.NormNum.Core"}