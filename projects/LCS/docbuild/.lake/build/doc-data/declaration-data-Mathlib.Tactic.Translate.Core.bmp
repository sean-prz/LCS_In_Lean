actic.Translate.warnAttrCore","kind":"def","line":845,"name":"Mathlib.Tactic.Translate.warnAttrCore","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L845-L857"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.copyInstanceAttribute\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">copyInstanceAttribute</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src </span><span class=\"fn\">tgt</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/CoreM.html#Lean.Core.CoreM\">Lean.CoreM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Copy the instance attribute in a `to_additive`\n\n[todo] it seems not to work when the `to_additive` is added as an attribute later. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.copyInstanceAttribute","kind":"def","line":836,"name":"Mathlib.Tactic.Translate.copyInstanceAttribute","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L836-L843"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.transformDeclRec\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">transformDeclRec</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfg</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">rootSrc </span><span class=\"fn\">rootTgt </span><span class=\"fn\">src</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">reorder</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\">Reorder</a> := <a href=\"./Init/Prelude.html#List.nil\">[</a><a href=\"./Init/Prelude.html#List.nil\">]</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/CoreM.html#Lean.Core.CoreM\">Lean.CoreM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Translate the declaration `src` and recursively all declarations `pre._proof_i`\noccurring in `src` using the `translations` dictionary.\n\n`replace_all`, `trace`, `ignore` and `reorder` are configuration options.\n\n`pre` is the declaration that got the translation attribute and `tgt_pre` is the target of this\ndeclaration. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.transformDeclRec","kind":"opaque","line":743,"name":"Mathlib.Tactic.Translate.transformDeclRec","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L743-L834"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.getRelevantArg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">getRelevantArg</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfg</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">relevantArg?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/CoreM.html#Lean.Core.CoreM\">Lean.CoreM</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span></div></div>","info":{"doc":"Return the `relevant_arg` option based on the computed `relevantArg?`\nand the given `cfg.relevantArg?`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.getRelevantArg","kind":"def","line":724,"name":"Mathlib.Tactic.Translate.getRelevantArg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L724-L741"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.findAuxDecls\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">findAuxDecls</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">decl</span> : <a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pre</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/CoreM.html#Lean.Core.CoreM\">Lean.CoreM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span></div></div>","info":{"doc":"Returns a `NameSet` of auxiliary constants in `decl` that might have been generated\nwhen adding `pre` to the environment, and which hence might need to be translated.\nExamples include `pre.match_5`, `pre._proof_2`, `someOtherDeclaration._proof_2` and `wrapped✝`.\nThe reason why we have to include `_proof_i` lemmas from other declarations is that there is a\ncache of such proofs, and previous such auxiliary proofs are reused when possible.\nThese auxiliary declarations may be private or not, independent of whether `pre` is private.\n`wrapped✝` is generated by `irreducible_def`, and it has macro scopes.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.findAuxDecls","kind":"def","line":706,"name":"Mathlib.Tactic.Translate.findAuxDecls","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L706-L722"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.findTargetName\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">findTargetName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">env</span> : <a href=\"./Lean/Environment.html#Lean.Environment\">Lean.Environment</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src </span><span class=\"fn\">rootSrc </span><span class=\"fn\">rootTgt</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/CoreM.html#Lean.Core.CoreM\">Lean.CoreM</a> <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a></span></div></div>","info":{"doc":"Find the target name of `src`, which is assumed to have been selected by `findAuxDecls`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.findTargetName","kind":"def","line":694,"name":"Mathlib.Tactic.Translate.findTargetName","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L694-L704"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.declUnfoldSimpAuxLemmas\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">declUnfoldSimpAuxLemmas</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">decl</span> : <a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> <a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a></span></div></div>","info":{"doc":"Unfold `simp` and `gcongr` auxlemmas in the type and value.\nThe reason why we can't just translate them is that they are generated by the `@[simp]` attribute,\nso it would require a change in the implementation of `@[simp]` to add these translateions.\nAdditionally, these lemmas have very short proofs, so unfolding them is not costly. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.declUnfoldSimpAuxLemmas","kind":"def","line":680,"name":"Mathlib.Tactic.Translate.declUnfoldSimpAuxLemmas","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L680-L692"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.updateAndAddDecl\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">updateAndAddDecl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">tgt</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">srcDecl</span> : <a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">reorder</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\">Reorder</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dont</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> (<a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span>)</span></div></div>","info":{"doc":"Translate the source declaration and then run `addDecl`. If the kernel throws an error,\ntry to emit a better error message.\n\nFor efficiency in `to_dual`, we first run `updateDecl` without any `UnfoldBoundaries`,\nand only if that fails do we try to include them.\nThe reason is that in the most common case, `to_dual` succeeds without needing to insert\nunfold boundaries, and figuring out whether to insert them can be quite expensive. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.updateAndAddDecl","kind":"def","line":639,"name":"Mathlib.Tactic.Translate.updateAndAddDecl","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L639-L678"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.updateDecl\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">updateDecl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">tgt</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">srcDecl</span> : <a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">reorder</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\">Reorder</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dont</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">unfoldBoundaries?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/UnfoldBoundary.html#Mathlib.Tactic.UnfoldBoundary.UnfoldBoundaries\">UnfoldBoundary.UnfoldBoundaries</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> (<a href=\"./Lean/Declaration.html#Lean.ConstantInfo\">Lean.ConstantInfo</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span>)</span></div></div>","info":{"doc":"Run `applyReplacementFun` on the given `srcDecl` to make a new declaration with name `tgt`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.updateDecl","kind":"def","line":613,"name":"Mathlib.Tactic.Translate.updateDecl","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L613-L637"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementLambda\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">applyReplacementLambda</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dontTranslate</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> (<a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span>)</span></div></div>","info":{"doc":"Run `applyReplacementFun` on an expression `fun x₁ .. xₙ ↦ e`,\nmaking sure not to translate type-classes on `xᵢ` if `i` is in `dontTranslate`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementLambda","kind":"def","line":595,"name":"Mathlib.Tactic.Translate.applyReplacementLambda","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L595-L611"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementForall\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">applyReplacementForall</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dontTranslate</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> (<a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span>)</span></div></div>","info":{"doc":"Run `applyReplacementFun` on an expression `∀ x₁ .. xₙ, e`,\nmaking sure not to translate type-classes on `xᵢ` if `i` is in `dontTranslate`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementForall","kind":"def","line":572,"name":"Mathlib.Tactic.Translate.applyReplacementForall","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L572-L593"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderLambda\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">reorderLambda</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">reorder</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\">Reorder</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a></span></div></div>","info":{"doc":"Reorder lambda-binders. See doc of `reorderAttr` for the interpretation of the argument ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderLambda","kind":"def","line":557,"name":"Mathlib.Tactic.Translate.reorderLambda","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L557-L570"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderForall\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">reorderForall</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">reorder</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\">Reorder</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a></span></div></div>","info":{"doc":"Reorder pi-binders. See doc of `reorderAttr` for the interpretation of the argument ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderForall","kind":"def","line":545,"name":"Mathlib.Tactic.Translate.reorderForall","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L545-L555"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.renameBinderNames\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">renameBinderNames</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">src</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a></div></div>","info":{"doc":"Rename binder names in pi type. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.renameBinderNames","kind":"def","line":539,"name":"Mathlib.Tactic.Translate.renameBinderNames","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L539-L543"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementFun\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">applyReplacementFun</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM\">ReplacementM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a></span></div></div>","info":{"doc":"`applyReplacementFun e` replaces the expression `e` with its translation.\nIt translates each identifier (inductive type, defined function etc) in an expression, unless\n* The identifier occurs in an application with `relevantArg` argument `arg`; and\n* `shouldTranslate arg` is false.\n\nIt will also reorder arguments of certain functions, using the stored `reorder`.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.applyReplacementFun","kind":"def","line":427,"name":"Mathlib.Tactic.Translate.applyReplacementFun","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L427-L537"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.List.swapFirstTwo\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">List</span>.<span class=\"name\">swapFirstTwo</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">α</span></span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">α</span></span></span></div></div>","info":{"doc":"Swap the first two elements of a list ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.List.swapFirstTwo","kind":"def","line":421,"name":"Mathlib.Tactic.Translate.List.swapFirstTwo","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L421-L425"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.shouldTranslate\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">shouldTranslate</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">env</span> : <a href=\"./Lean/Environment.html#Lean.Environment\">Lean.Environment</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">t</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.TranslateData\">TranslateData</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM\">ReplacementM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span></div></div>","info":{"doc":"`shouldTranslate e` tests whether the expression `e` contains a constant\nthat is not applied to any arguments and that doesn't have a translation itself.\nThis is used for deciding which subexpressions to translate: we only translate\nconstants if `shouldTranslate` applied to their relevant argument returns `true`.\nThis means we will replace expression applied to e.g. `α` or `α × β`, but not when applied to\ne.g. `ℕ` or `ℝ × α`.\nWe ignore all arguments specified by the `ignore` `NameMap`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.shouldTranslate","kind":"opaque","line":410,"name":"Mathlib.Tactic.Translate.shouldTranslate","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L410-L419"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM.run\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">ReplacementM</span>.<span class=\"name\">run</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dontTranslate </span><span class=\"fn\">allFVars</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.FVarId\">Lean.FVarId</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM\">ReplacementM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> (<span class=\"fn\">α</span> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span>)</span></div></div>","info":{"doc":"Run a `ReplacementM` computation, returning the result and the value of `relevant_arg` that\ncorresponds to this translation. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM.run","kind":"def","line":345,"name":"Mathlib.Tactic.Translate.ReplacementM.run","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L345-L350"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">ReplacementM</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Monad used by `applyReplacementFun`.\n- The reader stores the free variables on which nothing should be translated.\n- The state stores the free variables on which something has been translated.\n- The cache caches the results on subexpressions. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.ReplacementM","kind":"def","line":338,"name":"Mathlib.Tactic.Translate.ReplacementM","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L338-L343"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.etaExpandN\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">etaExpandN</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">Lean.MetaM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Lean.Expr</a></span></div></div>","info":{"doc":"Eta expands `e` exactly `n` times. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.etaExpandN","kind":"def","line":331,"name":"Mathlib.Tactic.Translate.etaExpandN","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L331-L336"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.none\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">Config</span>.<span class=\"name\">none</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"An optional flag for not giving the new declaration a user-facing name.\nThis is achieved by appending e.g. `_to_dual_1` to the name of the original declaration. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.none","kind":"def","line":329,"name":"Mathlib.Tactic.Translate.Config.none","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L329-L329"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.self\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">Config</span>.<span class=\"name\">self</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"An optional flag stating that the target of the translation is the target itself.\nThis can be used to reorder arguments, such as in\n`attribute [to_dual self (reorder := 3 4)] LE.le`.\nIf `self := true`, we should also have `existing := true`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.self","kind":"def","line":326,"name":"Mathlib.Tactic.Translate.Config.self","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L326-L326"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.existing\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">Config</span>.<span class=\"name\">existing</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"An optional flag stating that the translated declaration already exists.\nIf this flag is wrong about whether the translated declaration exists, we raise a linter error.\nNote: the linter will never raise an error for inductive types and structures. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.existing","kind":"def","line":321,"name":"Mathlib.Tactic.Translate.Config.existing","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L321-L321"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.ref\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">Config</span>.<span class=\"name\">ref</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a></div></div>","info":{"doc":"The `Syntax` element corresponding to the translation attribute,\nwhich we need for adding definition ranges, and for logging messages. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Config.ref","kind":"def","line":317,"name":"Mathlib.Tactic.Translate.Config.ref","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L317-L317"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.htm