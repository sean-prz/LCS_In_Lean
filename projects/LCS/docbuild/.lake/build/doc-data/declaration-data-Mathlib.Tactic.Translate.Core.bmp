7a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L170-L170"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.instBEqRelevantArg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">instBEqRelevantArg</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#BEq\">BEq</a> <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.instBEqRelevantArg","kind":"instance","line":170,"name":"Mathlib.Tactic.Translate.instBEqRelevantArg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L170-L170"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.instBEqRelevantArg.beq\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">instBEqRelevantArg</span>.<span class=\"name\">beq</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a> → <a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.instBEqRelevantArg.beq","kind":"def","line":170,"name":"Mathlib.Tactic.Translate.instBEqRelevantArg.beq","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L170-L170"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg.arg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">RelevantArg</span>.<span class=\"name\">arg</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></div></div>","info":{"doc":"Argument `n` needs to be checked. This is specified with `(relevant_arg := n)`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg.arg","kind":"ctor","line":168,"name":"Mathlib.Tactic.Translate.RelevantArg.arg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L168-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg.noArg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">RelevantArg</span>.<span class=\"name\">noArg</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\">RelevantArg</a></div></div>","info":{"doc":"No argument needs to be checked. This is specified with `(relevant_arg := _)`. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg.noArg","kind":"ctor","line":166,"name":"Mathlib.Tactic.Translate.RelevantArg.noArg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L166-L167"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">RelevantArg</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"`RelevantArg` represents an optional argument that should be checked to determine\nwhether or not to translate the given constant. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.RelevantArg","kind":"inductive","line":163,"name":"Mathlib.Tactic.Translate.RelevantArg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L163-L170"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">Reorder</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"`Reorder` represents a permutation of arguments in a translation.\nIt is specified with the `(reorder := ...)` notation using a disjoint cycle representation. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.Reorder","kind":"def","line":159,"name":"Mathlib.Tactic.Translate.Reorder","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L159-L161"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateRedundant\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateRedundant</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter used by translate attributes that checks if the attribute is redundant ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateRedundant","kind":"opaque","line":154,"name":"Mathlib.Tactic.Translate.linter.translateRedundant","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L154-L157"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateOverwrite\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateOverwrite</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter used by translate attributes that checks if the attribute was already applied ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateOverwrite","kind":"opaque","line":149,"name":"Mathlib.Tactic.Translate.linter.translateOverwrite","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L149-L152"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateRelevantArg\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateRelevantArg</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter used by translate attributes that checks if the relevant_arg is\nautomatically generated. ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateRelevantArg","kind":"opaque","line":142,"name":"Mathlib.Tactic.Translate.linter.translateRelevantArg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L142-L147"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateReorder\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateReorder</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter used by translate attributes that checks if the given reorder is\nequal to the automatically generated name ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateReorder","kind":"opaque","line":135,"name":"Mathlib.Tactic.Translate.linter.translateReorder","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L135-L140"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateExisting\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateExisting</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter to check whether the user correctly specified that the translated declaration already\nexists ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateExisting","kind":"opaque","line":128,"name":"Mathlib.Tactic.Translate.linter.translateExisting","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L128-L133"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateGenerateName\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">translateGenerateName</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter used by translate attributes that checks if the given declaration name is\nequal to the automatically generated name ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.translateGenerateName","kind":"opaque","line":121,"name":"Mathlib.Tactic.Translate.linter.translateGenerateName","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L121-L126"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.existingAttributeWarning\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">linter</span>.<span class=\"name\">existingAttributeWarning</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Linter, mostly used by translate attributes, that checks that the source declaration doesn't\nhave certain attributes ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.linter.existingAttributeWarning","kind":"opaque","line":114,"name":"Mathlib.Tactic.Translate.linter.existingAttributeWarning","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L114-L119"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.attrArgs\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">attrArgs</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.attrArgs","kind":"def","line":105,"name":"Mathlib.Tactic.Translate.attrArgs","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L105-L106"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.translationHint\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">translationHint</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"A hint about the translated declaration\n\n- `existing` indicates that the translated form of the declaration is a pre-existing declaration.\nThis is useful when the value cannot be translated, either because of a limitation in the\ntranslation heuristics, or because the value/proof is genuinely different.\n\n- `self` indicates that the declaration translates to itself, up to some reordering of arguments.\nIf no arguments are reordered then the attribute is redundant, which the `translateRedundant`\nlinter will warn about.\n\n- `none` indicates that the translated declaration should not get a user-facing name,\ninstead being named like an auxiliary declaration. This is particularly useful for `to_dual` when\nusing the `reassoc` attribute, because the dual of a right associated term is left associated,\nbut we only want user-facing lemmas with right associated terms.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.translationHint","kind":"def","line":88,"name":"Mathlib.Tactic.Translate.translationHint","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L88-L103"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.bracketedOption\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">bracketedOption</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.bracketedOption","kind":"def","line":85,"name":"Mathlib.Tactic.Translate.bracketedOption","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L85-L86"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.dontTranslateOption\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">dontTranslateOption</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`(dont_translate := ...)` takes a list of type variables (separated by spaces) that should not be\nconsidered for translation. For example in\n```\nlemma foo {α β : Type} [Group α] [Group β] (a : α) (b : β) : a * a⁻¹ = 1 ↔ b * b⁻¹ = 1\n```\nwe can choose to only translate `α` by writing `to_additive (dont_translate := β)`.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.dontTranslateOption","kind":"def","line":76,"name":"Mathlib.Tactic.Translate.dontTranslateOption","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L76-L84"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.relevantArgOption\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">relevantArgOption</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"the `(relevant_arg := ...)` option tells which argument to look at to determine whether to\ntranslate this constant. This is inferred automatically,\nbut it can also be overwritten using this syntax.\n\nIf there are multiple possible arguments, we typically tag the first one.\nIf this argument contains a fixed type, this declaration will not be translated.\nSee the Heuristics section of the `to_additive` doc-string for more details.\n\nWhen it cannot be inferred automatically, it is presumed that the first argument is relevant.\n\nUse `(relevant_arg := _)` to indicate that there is no relevant argument.\n\nImplementation note: we only allow exactly 1 relevant argument, even though some declarations\n(like `Prod.instGroup`) have multiple relevant arguments.\nThe reason is that whether we translate a declaration is an all-or-nothing decision, and\nwe will not be able to translate declarations that (e.g.) talk about multiplication on `ℕ × α`\nanyway.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.relevantArgOption","kind":"def","line":56,"name":"Mathlib.Tactic.Translate.relevantArgOption","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L56-L75"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderOption\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">reorderOption</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`(reorder := ...)` reorders the arguments/hypotheses in the generated declaration.\nIt uses cycle notation. For example `(reorder := α β, 5 6)` swaps the arguments `α` and `β`\nwith each other and the fifth and the sixth argument, and `(reorder := 3 4 5)` will move\nthe fifth argument before the third argument. This is used in `to_dual` to swap the arguments in\n`≤`, `<` and `⟶`. It is also used in `to_additive` to translate from `a ^ n` to `n • a`.\n\nIf the translated declaration already exists (i.e. when using `existing` or `self`), this is\ninferred automatically using the function `guessReorder`.\n","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.reorderOption","kind":"def","line":45,"name":"Mathlib.Tactic.Translate.reorderOption","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L45-L55"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.attrOption\"><span class=\"name\">Mathlib</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Translate</span>.<span class=\"name\">attrOption</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`(attr := ...)` applies the given attributes to the original and the translated declaration.\nIn the case of `to_additive`, we may want to apply it multiple times,\n(such as in `a ^ n` -> `n • a` -> `n +ᵥ a`). In this case, you should use the syntax\n`to_additive (attr := some_other_attr, to_additive)`, which will apply `some_other_attr` to all\nthree generated declarations.\n ","docLink":"./Mathlib/Tactic/Translate/Core.html#Mathlib.Tactic.Translate.attrOption","kind":"def","line":38,"name":"Mathlib.Tactic.Translate.attrOption","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/8f9d9cff6bd728b17a24e163c9402775d9e6a365/Mathlib/Tactic/Translate/Core.lean#L38-L44"}}],"imports":["Init","Lean.Compiler.NoncomputableAttr","Lean.Elab.Tactic.Ext","Lean.Meta.Tactic.Rfl","Lean.Meta.Tactic.Symm","Mathlib.Data.Array.Defs","Mathlib.Lean.Meta.Simp","Mathlib.Tactic.Simps.Basic","Lean.Meta.CoeAttr","Batteries.Lean.NameMapAttribute","Batteries.Tactic.Trans","Mathlib.Tactic.Eqns","Mathlib.Tactic.Simps.Basic","Mathlib.Tactic.Translate.GuessName","Mathlib.Tactic.Translate.UnfoldBoundary"],"instances":[{"className":"BEq","name":"Mathlib.Tactic.Translate.instBEqRelevantArg","typeNames":["Mathlib.Tactic.Translate.RelevantArg"]},{"className":"Inhabited","name":"Mathlib.Tactic.Translate.instInhabitedRelevantArg","typeNames":["Mathlib.Tactic.Translate.RelevantArg"]},{"className":"Lean.ToMessageData","name":"Mathlib.Tactic.Translate.instToMessageDataRelevantArg","typeNames":["Mathlib.Tactic.Translate.RelevantArg"]}],"name":"Mathlib.Tactic.Translate.Core"}