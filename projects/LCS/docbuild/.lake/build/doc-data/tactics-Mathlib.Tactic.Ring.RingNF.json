  "internalName": "Mathlib.Tactic.RingNF.ringNF",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "ring_nf"}]]},
        {"text":
         " simplifies expressions in the language of commutative (semi)rings,"},
        {"raw": "\n"},
        {"text":
         "which rewrites all ring expressions into a normal form, allowing variables in the exponents."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "ring_nf"}]]},
        {"text": " works as both a tactic and a conv tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "See also the "},
        {"element": ["code", true, [], [{"text": "ring"}]]},
        {"text":
         " tactic for solving a goal which is an equation in the language"},
        {"raw": "\n"},
        {"text": "of commutative (semi)rings."}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "ring_nf!"}]]},
           {"text":
            " will use a more aggressive reducibility setting to identify atoms."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "ring_nf"},
              {"text": " "},
              {"text": "(config"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "cfg)"}]]},
           {"text": " allows for additional configuration (see "},
           {"element": ["code", true, [], [{"text": "RingNF.Config"}]]},
           {"text": "):"},
           {"element":
            ["ul",
             true,
             [],
             [{"element":
               ["li",
                true,
                [],
                [{"element": ["code", true, [], [{"text": "red"}]]},
                 {"text": ": the reducibility setting (overridden by "},
                 {"element": ["code", true, [], [{"text": "!"}]]},
                 {"text": ")"}]]},
              {"element":
               ["li",
                true,
                [],
                [{"element": ["code", true, [], [{"text": "zetaDelta"}]]},
                 {"text":
                  ": if true, local let variables can be unfolded (overridden by "},
                 {"element": ["code", true, [], [{"text": "!"}]]},
                 {"text": ")"}]]},
              {"element":
               ["li",
                true,
                [],
                [{"element": ["code", true, [], [{"text": "recursive"}]]},
                 {"text": ": if true, "},
                 {"element": ["code", true, [], [{"text": "ring_nf"}]]},
                 {"text": " will also recurse into atoms"}]]}]]}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "ring_nf"},
              {"text": " "},
              {"text": "at"},
              {"text": " "},
              {"text": "l1"},
              {"text": " "},
              {"text": "l2"},
              {"text": " "},
              {"text": "..."}]]},
           {"text": " can be used to rewrite at the given locations."}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "Examples:"},
        {"raw": "\n"},
        {"text":
         "This can be used non-terminally to normalize ring expressions in the goal such as"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "⊢"},
           {"text": " "},
           {"text": "P"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "x)"}]]},
        {"text": " ~> "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "⊢"},
           {"text": " "},
           {"text": "P"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": "*"},
           {"text": " "},
           {"text": "3)"}]]},
        {"text": ", as well as being able to prove some equations that"},
        {"raw": "\n"},
        {"element": ["code", true, [], [{"text": "ring"}]]},
        {"text":
         " cannot because they involve ring reasoning inside a subterm, such as"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "sin"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "y)"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "sin"},
           {"text": " "},
           {"text": "(y"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "x)"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "2"},
           {"text": " "},
           {"text": "*"},
           {"text": " "},
           {"text": "sin"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "y)"}]]},
        {"text": "."}]]}]]},
