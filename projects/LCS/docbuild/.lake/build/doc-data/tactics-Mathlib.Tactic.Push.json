  "internalName": "Mathlib.Tactic.Push.push_neg",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "push_neg"}]]},
        {"text":
         " rewrites the goal by pushing negations deeper into an expression."},
        {"raw": "\n"},
        {"text": "For instance, the goal "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "¬"},
           {"text": " "},
           {"text": "∀"},
           {"text": " "},
           {"text": "x,"},
           {"text": " "},
           {"text": "∃"},
           {"text": " "},
           {"text": "y,"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "≤"},
           {"text": " "},
           {"text": "y"}]]},
        {"text": " will be transformed by "},
        {"element": ["code", true, [], [{"text": "push_neg"}]]},
        {"text": " into"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "∃"},
           {"text": " "},
           {"text": "x,"},
           {"text": " "},
           {"text": "∀"},
           {"text": " "},
           {"text": "y,"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "<"},
           {"text": " "},
           {"text": "x"}]]},
        {"text":
         ". Binder names are preserved (contrary to what would happen with "},
        {"element": ["code", true, [], [{"text": "simp"}]]},
        {"raw": "\n"},
        {"text": "using the relevant lemmas). "},
        {"element": ["code", true, [], [{"text": "push_neg"}]]},
        {"text": " works as both a tactic and a conv tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "push_neg"}]]},
        {"text": " is a special case of the more general "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": " tactic, namely "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "push"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#Not"]],
             [{"text": "Not"}]]}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text": "The "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": " tactic can be extended using the "},
        {"element": ["code", true, [], [{"text": "@[push]"}]]},
        {"text": " attribute. "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": " has special-casing"},
        {"raw": "\n"},
        {"text": "built in for "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "push"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#Not"]],
             [{"text": "Not"}]]}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "Tactics that introduce a negation usually have a version that automatically calls "},
        {"element": ["code", true, [], [{"text": "push_neg"}]]},
        {"text": " on"},
        {"raw": "\n"},
        {"text": "that negation. These include "},
        {"element": ["code", true, [], [{"text": "by_cases!"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "contrapose!"}]]},
        {"text": " and "},
        {"element": ["code", true, [], [{"text": "by_contra!"}]]},
        {"text": "."}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "push_neg"},
              {"text": " "},
              {"text": "at"},
              {"text": " "},
              {"text": "l1"},
              {"text": " "},
              {"text": "l2"},
              {"text": " "},
              {"text": "..."}]]},
           {"text": " rewrites at the given locations."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "push_neg"},
              {"text": " "},
              {"text": "at"},
              {"text": " "},
              {"text": "*"}]]},
           {"text": " rewrites at each hypothesis and the goal."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "push_neg"}, {"text": " "}, {"text": "+distrib"}]]},
           {"text": " rewrites "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "¬"},
              {"text": " "},
              {"text": "(p"},
              {"text": " "},
              {"text": "∧"},
              {"text": " "},
              {"text": "q)"}]]},
           {"text": " into "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "¬"},
              {"text": " "},
              {"text": "p"},
              {"text": " "},
              {"text": "∨"},
              {"text": " "},
              {"text": "¬"},
              {"text": " "},
              {"text": "q"}]]},
           {"text": " (by default, the tactic rewrites it"},
           {"raw": "\n"},
           {"text": "into "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "p"},
              {"text": " "},
              {"text": "→"},
              {"text": " "},
              {"text": "¬"},
              {"text": " "},
              {"text": "q"}]]},
           {"text": " instead)."}]]}]]},
     {"element": ["p", true, [], [{"text": "Example:"}]]},
