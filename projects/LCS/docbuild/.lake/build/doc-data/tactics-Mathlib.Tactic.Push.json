           {"text": "...)"}]]},
        {"text": " (where "},
        {"element": ["code", true, [], [{"text": "c"}]]},
        {"text": " can appear 0 or more times on the right hand side)."},
        {"raw": "\n"},
        {"text": "To extend the "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": " tactic, you can tag a lemma of this form with the "},
        {"element": ["code", true, [], [{"text": "@[push]"}]]},
        {"text": " attribute."}]]},
