           {"text": " "},
           {"text": "∈"},
           {"text": " "},
           {"text": "z"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text": "More precisely, the "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text":
         " tactic repeatedly rewrites an expression by applying lemmas"},
        {"raw": "\n"},
        {"text": "of the form "},
