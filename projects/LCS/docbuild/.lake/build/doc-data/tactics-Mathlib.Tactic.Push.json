       [{"element":
         ["code", true, [], [{"text": "push"}, {"text": " "}, {"text": "c"}]]},
        {"text": " rewrites the goal by pushing the constant "},
        {"element": ["code", true, [], [{"text": "c"}]]},
        {"text": " deeper into an expression."},
        {"raw": "\n"},
        {"text": "For instance, "},
        {"element":
