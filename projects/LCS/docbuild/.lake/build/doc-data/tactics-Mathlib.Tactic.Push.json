 {"userName": "pull",
  "tags": [],
  "internalName": "Mathlib.Tactic.Push.pull",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element":
         ["code", true, [], [{"text": "pull"}, {"text": " "}, {"text": "c"}]]},
        {"text": " rewrites the goal by pulling the constant "},
        {"element": ["code", true, [], [{"text": "c"}]]},
        {"text": " closer to the head of the expression."},
        {"raw": "\n"},
        {"text": "For instance, "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "pull"},
           {"text": " "},
           {"text": "_"},
           {"text": " "},
           {"text": "∈"},
           {"text": " "},
           {"text": "_"}]]},
        {"text": " rewrites "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "x"},
           {"text": " "},
           {"text": "∈"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "∨"},
           {"text": " "},
           {"text": "¬"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "∈"},
           {"text": " "},
           {"text": "z"}]]},
        {"text": " into "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "x"},
           {"text": " "},
           {"text": "∈"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "∪"},
           {"text": " "},
           {"text": "zᶜ"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text": "More precisely, the "},
        {"element": ["code", true, [], [{"text": "pull"}]]},
        {"text":
         " tactic repeatedly rewrites an expression by applying lemmas"},
        {"raw": "\n"},
        {"text": "of the form "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "..."},
           {"text": " "},
           {"text": "(c"},
           {"text": " "},
           {"text": "...)"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "c"},
           {"text": " "},
           {"text": "..."}]]},
        {"text": " (where "},
        {"element": ["code", true, [], [{"text": "c"}]]},
        {"text": " can appear 1 or more times on the left hand side)."},
        {"raw": "\n"},
        {"element": ["code", true, [], [{"text": "pull"}]]},
        {"text": " is the inverse tactic to "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": ". To extend the "},
        {"element": ["code", true, [], [{"text": "pull"}]]},
        {"text": " tactic, you can tag a lemma"},
        {"raw": "\n"},
        {"text": "with the "},
        {"element": ["code", true, [], [{"text": "@[push]"}]]},
        {"text": " attribute. "},
        {"element": ["code", true, [], [{"text": "pull"}]]},
        {"text": " works as both a tactic and a conv tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "A lemma is considered a "},
        {"element": ["code", true, [], [{"text": "pull"}]]},
        {"text": " lemma if its reverse direction is a "},
        {"element": ["code", true, [], [{"text": "push"}]]},
        {"text": " lemma"},
        {"raw": "\n"},
        {"text":
         "that actually moves the given constant away from the head. For example"}]]},
     {"element":
